      "writtenOn": "2014-09-11T20:57:16Z",
      "side": 1,
      "message": "Monasca doesn\u0027t have a \"datapoints\" resource right now and this code.",
      "revId": "abaf9e2b2c41a167b79388aa3c4f482f81ae7887",
