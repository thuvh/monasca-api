      },
      "writtenOn": "2014-09-11T20:57:16Z",
      "side": 1,
      "message": "Do we really want to sleep in the case that Kafka is unavailable or just return to the client a 500 or 503 error?",
      "revId": "abaf9e2b2c41a167b79388aa3c4f482f81ae7887",
      "serverId": "4a232e18-c5a9-48ee-94c0-e04e7cca6543",
