        "id": 2860
      },
      "writtenOn": "2014-09-11T21:31:36Z",
      "side": 1,
      "message": "remember the retries. want to sleep a bit then retry. Unless we do not do\nretry.",
      "parentUuid": "fa98f980_9c3d142e",
      "revId": "abaf9e2b2c41a167b79388aa3c4f482f81ae7887",
      "serverId": "4a232e18-c5a9-48ee-94c0-e04e7cca6543",
