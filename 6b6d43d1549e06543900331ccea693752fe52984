      "message": "It looks like in other tables you rely on the default charset and collate settings, but here they are explicit. Is there a reason for that?",
      "range": {
        "startLine": 409,
        "startChar": 55,
        "endLine": 409,
        "endChar": 73
      },
      "revId": "6b6d43d1549e06543900331ccea693752fe52984",
