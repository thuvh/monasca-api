      "key": {
        "uuid": "bab6814e_d5cc466c",
        "filename": "java/src/main/java/monasca/api/app/command/CreateNotificationMethodCommand.java",
        "patchSetId": 18
      },
      "lineNbr": 44,
      "author": {
        "id": 2419
      },
      "writtenOn": "2016-05-20T03:05:24Z",
      "side": 1,
      "message": "This seems like a problem that already exists, but if equals if overridden, then hashCode should be too, otherwise it is a violation of the contract.\n\nA common source of bugs is the failure to override the hashCode method. You must override hashCode in every class that overrides equals. Failure to do so will result in a violation of the general contract for Object.hashCode, which will prevent your class from functioning properly in conjunction with all hash-based collections, including HashMap, HashSet, and Hashtable.\n\n\nThe key provision that is violated when you fail to override hashCode is the second one: equal objects must have equal hash codes.",
      "range": {
        "startLine": 44,
        "startChar": 17,
        "endLine": 44,
        "endChar": 23
      },
      "revId": "2a14276a0cf5f03a1acc5a6854772041abfe9c83",
      "serverId": "4a232e18-c5a9-48ee-94c0-e04e7cca6543",
      "unresolved": false
    },
